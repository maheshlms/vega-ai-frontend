# Frontend Auth0 configuration
# Create a .env.local file in the Frontend directory as this file is to provide a template.
# Fill in your Auth0 values. Do NOT commit secrets.

# Example domain: dev-xxxxx.us.auth0.com (no protocol)
# VITE_AUTH0_DOMAIN=
 
# Your SPA Application Client ID from Auth0 Dashboard > Applications > Applications
# VITE_AUTH0_CLIENT_ID=

# The API Audience you configured in Auth0 (Identifier)
# VITE_AUTH0_AUDIENCE=

# HMR host for Vite dev server (set to your public IP or hostname for remote access)
# VITE_HMR_HOST=localhost

# Backend URL used by frontend API client
# VITE_BACKEND_URL=http://localhost:8000

# Microservice URLs
# VITE_AUDIT_SERVICE_URL=http://localhost:8002
# VITE_TARGET_SYSTEMS_URL=http://localhost:8000
# VITE_LLM_RUNTIME_URL=http://localhost:8000

# Optional integrations — leave blank if not using
# VITE_HEYGEN_API_KEY=
